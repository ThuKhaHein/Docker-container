<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let chartInstances = {};
    let dashboardData = <?php echo json_encode($dashboardData); ?>;
    let allRecords = <?php echo json_encode($allRecords); ?>;

    document.addEventListener('DOMContentLoaded', function() {
        renderDashboard(dashboardData);
        setupFormHandlers();

        // Set default date to today
        document.getElementById('date').value = new Date().toISOString().split('T')[0];
    });

    function showPage(pageId) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById(pageId + '-page').classList.add('active');

        document.querySelectorAll('.btn-outline-primary, .btn-outline-secondary').forEach(btn => {
            btn.classList.remove('active');
        });

        if(pageId === 'dashboard') {
            document.querySelector('button[onclick="showPage(\'dashboard\')"]').classList.add('active');
        } else {
            document.querySelector('button[onclick="showPage(\'inventory\')"]').classList.add('active');
        }
    }

    function applyDashboardFilter() {
        const startDate = document.getElementById('start-date').value;
        const endDate = document.getElementById('end-date').value;

        fetch('', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `action=get_dashboard_data&start_date=${startDate}&end_date=${endDate}`
        })
        .then(response => response.json())
        .then(data => {
            updateDashboard(data);
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error loading dashboard data');
        });
    }

    function resetDashboardFilter() {
        document.getElementById('start-date').value = '';
        document.getElementById('end-date').value = '';
        updateDashboard(dashboardData);

        // Update recent activity table
        const tbody = document.getElementById('recent-activity-table').querySelector('tbody');
        tbody.innerHTML = '';
        if(dashboardData.recentActivity && dashboardData.recentActivity.length > 0) {
            dashboardData.recentActivity.forEach(activity => {
                const row = tbody.insertRow();
                row.innerHTML = `
                    <td>${activity.date}</td>
                    <td>${activity.type}</td>
                    <td>${activity.quantity}</td>
                    <td>${activity.sourceDest}</td>
                `;
            });
        } else {
            tbody.innerHTML = '<tr><td colspan="4" style="text-align: center;">No activity in selected range.</td></tr>';
        }
    }

    function updateDashboard(data) {
        document.getElementById('current-stock').textContent = data.scorecards.currentStock;
        document.getElementById('total-received').textContent = data.scorecards.totalReceived;
        document.getElementById('total-usage').textContent = data.scorecards.totalUsage;
        document.getElementById('avg-usage').textContent = data.scorecards.avgUsage;

        renderDashboard(data);

        // Update recent activity table
        const tbody = document.getElementById('recent-activity-table').querySelector('tbody');
        tbody.innerHTML = '';

        if(data.recentActivity && data.recentActivity.length > 0) {
            data.recentActivity.forEach(activity => {
                const row = tbody.insertRow();
                row.innerHTML = `
                    <td>${activity.date}</td>
                    <td>${activity.type}</td>
                    <td>${activity.quantity}</td>
                    <td>${activity.sourceDest}</td>
                `;
            });
        } else {
            tbody.innerHTML = '<tr><td colspan="4" style="text-align: center;">No activity in selected range.</td></tr>';
        }
    }

    function renderDashboard(data) {
        if (data) {
            renderChart('monthlyUsageChart', 'bar', data.monthlyUsage.labels, data.monthlyUsage.data, 'Liters Used', '#198754');
            renderChart('usageByEquipmentChart', 'doughnut', data.usageByEquipment.labels, data.usageByEquipment.data);
            renderChart('receivedBySupplierChart', 'pie', data.receivedBySupplier.labels, data.receivedBySupplier.data);
        }
    }

    function renderChart(canvasId, type, labels, data, label = '', color = null) {
        const canvas = document.getElementById(canvasId);
        if (!canvas) return;

        const ctx = canvas.getContext('2d');

        if (chartInstances[canvasId]) {
            chartInstances[canvasId].destroy();
        }

        const colors = ['#0d6efd', '#6c757d', '#198754', '#ffc107', '#dc3545', '#0dcaf0', '#fd7e14'];

        chartInstances[canvasId] = new Chart(ctx, {
            type: type,
            data: {
                labels: labels,
                datasets: [{
                    label: label,
                    data: data,
                    backgroundColor: (type === 'doughnut' || type === 'pie') ? colors : (color || '#0d6efd')
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: (type === 'doughnut' || type === 'pie')
                    }
                },
                scales: (type === 'line' || type === 'bar') ? {
                    y: {
                        beginAtZero: true
                    }
                } : {}
            }
        });
    }

    function setupFormHandlers() {
        const form = document.getElementById('inventory-form');
        const transactionType = document.getElementById('transaction-type');

        form.addEventListener('submit', handleFormSubmit);
        transactionType.addEventListener('change', handleTransactionTypeChange);

        // Initialize form state
        handleTransactionTypeChange();
    }

    function handleTransactionTypeChange() {
        const type = document.getElementById('transaction-type').value;
        const receivedFields = document.getElementById('received-fields');
        const usageFields = document.getElementById('usage-fields');

        receivedFields.style.display = 'none';
        usageFields.style.display = 'none';

        if(type === 'Diesel Received') {
            receivedFields.style.display = 'block';
        } else if(type === 'Diesel Usage') {
            usageFields.style.display = 'block';
        }
    }

    function handleFormSubmit(e) {
        e.preventDefault();

        const formData = new FormData(e.target);
        formData.append('action', 'save_record');

        fetch('', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(result => {
            if(result.status === 'success') {
                alert(result.message);
                clearForm();
                loadRecords();
                // Refresh dashboard data
                applyDashboardFilter();
            } else {
                alert('Error: ' + result.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error saving record');
        });
    }

    function editRecord(id) {
        const record = allRecords.find(r => r.id === id);
        if(record) {
            document.getElementById('record-id').value = record.id;
            document.getElementById('date').value = record.date;
            document.getElementById('transaction-type').value = record.transactionType;
            document.getElementById('quantity-liters').value = record.quantityLiters;
            document.getElementById('notes').value = record.notes || '';

            handleTransactionTypeChange();

            if(record.transactionType === 'Diesel Received') {
                document.getElementById('supplier-name').value = record.sourceOrDestination;
                document.getElementById('price-per-liter').value = record.pricePerLiter || '';
            } else {
                document.getElementById('vehicle-equipment').value = record.sourceOrDestination;
            }

            document.getElementById('form-title').textContent = 'Edit Entry';
            showPage('inventory');
        }
    }

    function deleteRecord(id) {
        if(confirm('Are you sure you want to delete this entry?')) {
            fetch('', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `action=delete_record&id=${id}`
            })
            .then(response => response.json())
            .then(result => {
                if(result.status === 'success') {
                    alert(result.message);
                    loadRecords();
                    applyDashboardFilter();
                } else {
                    alert('Error: ' + result.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error deleting record');
            });
        }
    }

    function loadRecords() {
        fetch('', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'action=get_records'
        })
        .then(response => response.json())
        .then(records => {
            allRecords = records;
            updateInventoryTable(records.slice(0, 10));
        })
        .catch(error => {
            console.error('Error:', error);
        });
    }

    function updateInventoryTable(records) {
        const tbody = document.getElementById('inventory-tbody');
        tbody.innerHTML = '';

        if(records.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align: center;">No records found.</td></tr>';
            return;
        }

        records.forEach(record => {
            const row = tbody.insertRow();
            row.innerHTML = `
                <td>${record.date}</td>
                <td>${record.transactionType}</td>
                <td>${record.quantityLiters}</td>
                <td>${record.pricePerLiter || '-'}</td>
                <td>${record.sourceOrDestination}</td>
                <td>${record.notes || '-'}</td>
                <td class="actions-cell">
                    <button class="btn-edit" onclick="editRecord('${record.id}')">Edit</button>
                    <button class="btn-delete" onclick="deleteRecord('${record.id}')">Delete</button>
                </td>
            `;
        });
    }

    function clearForm() {
        document.getElementById('inventory-form').reset();
        document.getElementById('record-id').value = '';
        document.getElementById('form-title').textContent = 'Add New Inventory Entry';
        document.getElementById('date').value = new Date().toISOString().split('T')[0];
        handleTransactionTypeChange();
    }
</script>

<?php include '../templates/footer.php'; ?>
